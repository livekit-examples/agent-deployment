# LiveKit connection
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# AWS credentials (for Bedrock LLM, Polly TTS, Transcribe STT, and KVS TURN)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# TURN provider: "kvs" for KVS Managed TURN, "static" for third-party
TURN_PROVIDER=static

# -- KVS Managed TURN (TURN_PROVIDER=kvs) --
# Auto-rotating credentials via GetIceServerConfig API.
# Channel created automatically if it doesn't exist.
# Cost: $0.03/month per channel. Rate limit: 5 TPS per channel.
KVS_CHANNEL_NAME=livekit-agent-turn

# -- Third-party TURN (TURN_PROVIDER=static) --
# Static credentials. TCP TURN recommended for VPC.
# Providers: Cloudflare, Twilio, metered.ca
TURN_SERVER_URLS=turn:turn.example.com:443?transport=tcp
TURN_SERVER_USERNAME=
TURN_SERVER_CREDENTIAL=
